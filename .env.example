# alt-nfp environment template — copy to `.env` (gitignored) and fill in.
#
# CONTAINER CONTRACT (plans/15): on Bloomberg the compute container has a tiny
# disk footprint and forbids writes under ./data. Every PERSISTENT artifact must
# therefore live in object storage (S3), selected by the four *_URI vars below.
# Leave a URI UNSET to fall back to the local ./data tree (dev / CI only — never
# on Bloomberg). Rebuild scratch (raw downloads, HTTP cache, SAE checkpoint) goes
# to tempfile automatically and needs no env var.

# ---------------------------------------------------------------------------
# Object-storage roots (the container contract — set ALL FOUR on Bloomberg)
# ---------------------------------------------------------------------------
# Vintage store (Hive-partitioned CES/QCEW). Rebuilds target a scratch prefix
# (…/store-rebuild) and are promoted to …/store deliberately — never build
# straight to the canonical store.
NFP_STORE_URI=s3://alt-nfp/store

# Hash-pinned ModelData snapshots (.npz arrays + embedded JSON meta).
NFP_SNAPSHOTS_URI=s3://alt-nfp/snapshots

# Persistent non-store data the production nowcast reads every run:
# indicators/, competitors/consensus.parquet, intermediate/{vintage,release}_dates.parquet.
NFP_DATA_URI=s3://alt-nfp

# Consensus survey file (Total '00' + private '05'); unset ⇒ local data/competitors/consensus.parquet
NFP_CONSENSUS_PATH=s3://alt-nfp/competitors/consensus.parquet

# Provider parquets — a SEPARATE store from the alt-nfp bucket (lives on its own
# Bloomberg compute store; NOT seeded by this repo). Set to that store's root.
NFP_PROVIDERS_URI=s3://alt-nfp-providers

# ---------------------------------------------------------------------------
# Object-storage credentials (used by all of the above)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Local MinIO (Bloomberg S3 stand-in): http://127.0.0.1:9000
# Real AWS S3: leave UNSET so boto/s3fs use the default endpoint.
AWS_ENDPOINT_URL=http://127.0.0.1:9000
# Optional; some S3 setups require a region.
# AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Data-acquisition API keys (rebuild / monthly-capture paths only)
# ---------------------------------------------------------------------------
# FRED/ALFRED — required to download cyclical indicators (and SAE, if enabled).
FRED_API_KEY=your-fred-api-key

# BLS Public Data API — optional; enables v2 (higher rate limits, 20-yr windows)
# and the JSON fallback in releases.py. Unset uses the v1 API.
# BLS_API_KEY=your-bls-api-key

# Contact email for download.bls.gov LABSTAT bulk fetches. Akamai 403s a bare
# product UA on the heavy files and any UA containing the 'github.com' token.
# A non-PII address is fine; must not be a github.com domain.
BLS_CONTACT_EMAIL=alt-nfp@example.com

# ---------------------------------------------------------------------------
# Optional overrides / test-only
# ---------------------------------------------------------------------------
# Override the local data root (ignored once the *_URI vars above are set).
# NFP_BASE_DIR=/path/to/local/data-root

# Golden-master parity fixtures (test-only; default s3://alt-nfp/golden/a1).
# NFP_GOLDEN_URI=s3://alt-nfp/golden/a1

# Canonical store URI for the rebuild-gate parity test (maintainer-only; the
# gate self-skips when unset).
# NFP_LEGACY_STORE_URI=s3://alt-nfp/store
